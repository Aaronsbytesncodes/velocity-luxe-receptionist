# Notifications (optional for MVP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=

# Admin bootstrap (first contractor signup)
ADMIN_SECRET=change-me-in-production
