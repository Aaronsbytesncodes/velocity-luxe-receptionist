# App
NEXT_PUBLIC_APP_URL=https://velocity-luxe-receptionist.vercel.app
# Neon: use the POOLED connection string on Vercel (host contains -pooler)
# Dashboard → Connection details → "Pooled connection"
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Vapi — https://dashboard.vapi.ai
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Cal.com — each contractor can use their own key in onboarding;
# platform key optional for managed bookings
CALCOM_API_KEY=

# Notifications (optional for MVP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=

# Admin bootstrap (first contractor signup)
ADMIN_SECRET=change-me-in-production
