# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Local: free Postgres at https://neon.tech (copy connection string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Vapi — https://dashboard.vapi.ai
VAPI_API_KEY=
